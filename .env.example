# Puerto (Railway lo inyecta automáticamente, no hace falta tocarlo)
PORT=3000

# Corre el navegador visible (false) o headless (true, recomendado en Railway)
HEADLESS=true

# Pausa en ms entre cliente y cliente, para no parecer un bot agresivo
DELAY_MS=3000

# Rango de fechas por defecto para "Mis Comprobantes" (formato dd/mm/aaaa - dd/mm/aaaa)
RANGO_FECHAS=01/07/2025 - 30/06/2026

# Clave simple para proteger el endpoint (opcional pero MUY recomendado
# porque este backend maneja claves fiscales de clientes)
API_KEY=cambiame-por-una-clave-larga-y-random

# Dominio del frontend en Vercel, para CORS. Usar "*" solo en pruebas.
FRONTEND_ORIGIN=https://tu-app.vercel.app
